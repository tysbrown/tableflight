{
  "name": "board-engine",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/board-engine/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/Cargo.toml",
        "{projectRoot}/Cargo.lock"
      ],
      "outputs": ["{projectRoot}/pkg"],
      "options": {
        "command": "PATH=\"$HOME/.cargo/bin:$PATH\" wasm-pack build --target web --out-dir pkg --release",
        "cwd": "libs/board-engine"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo test",
        "cwd": "libs/board-engine"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo clippy -- -D warnings",
        "cwd": "libs/board-engine"
      }
    }
  }
}
